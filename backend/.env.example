NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://datadash:datadash_secret@localhost:5432/datadash

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Python Microservice
PYTHON_SERVICE_URL=http://localhost:8000

# File Storage (local or s3)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# AWS S3 (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=datadash-uploads

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@datadash.io

# Frontend URL
FRONTEND_URL=http://localhost:3000
